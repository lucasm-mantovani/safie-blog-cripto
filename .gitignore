# Credenciais e ambiente
.env
*.env.local

# Logs (não versionados)
logs/

# Dados operacionais (podem conter tokens em mensagens de erro)
dados/consumo_apify.json
dados/noticia_selecionada.json
dados/artigo_gerado.json

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
.Python

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*.swo

# backups locais (nunca versionar)
.env.bkp*
.env.backup*
*.bkp.*
.git/config.bkp.*

# Forense Claude — resposta crua, regenerada a cada run
dados/ultima_resposta_claude.txt

# Estado de deduplicação — gerenciado pelo pipeline, não versionar (decisão #005, 16/06/2026)
dados/historico_noticias.json

# Marcador de tentativas diárias — estado interno do watchdog (Direção 1)
dados/tentativas_*.json
